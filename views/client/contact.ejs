<%- include('../partials/header', {title: 'Contact'}) %>
<%- include('../partials/navbar') %>

<div class="page-hero">
  <div class="container">
    <h1>Contact Us</h1>
    <p>We'd love to help plan your perfect trip</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      <div>
        <h2>Get in Touch</h2>
        <p>Our travel experts are available Monday to Saturday, 9am–7pm IST.</p>
        <div class="contact-items">
          <div class="contact-item">📍 12 Park Street, Kolkata – 700016</div>
          <div class="contact-item">📞 +91 9078353023</div>
          <div class="contact-item">✉️ hello@wondervoyage.in</div>
          <div class="contact-item">
            <a href="https://wa.me/919800000000?text=Hi%2C%20I%20want%20to%20enquire%20about%20a%20travel%20package" target="_blank" class="btn btn-whatsapp">
              💬 Chat on WhatsApp
            </a>
          </div>
        </div>
      </div>
      <div class="contact-form-wrap">
        <form class="contact-form">
          <div class="form-group">
            <label>Your Name</label>
            <input type="text" class="form-control" placeholder="John Doe">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control" placeholder="john@example.com">
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea class="form-control" rows="4" placeholder="Tell us about your dream trip..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
