<%- include('../partials/header', {title: 'Vehicles'}) %>
<% let currentPage = 'vehicles' %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-page-header">
  <h1>Vehicles</h1>
</div>

<div class="admin-card" style="max-width:600px;margin-bottom:2rem">
  <h3>Add Vehicle</h3>
  <form method="POST" action="/admin/vehicles/add" class="form-row-wrap">
    <div class="form-group"><label>Vehicle Name</label><input name="vehicle_name" class="form-control" placeholder="Toyota Innova" required></div>
    <div class="form-group"><label>Plate Number</label><input name="plate_number" class="form-control" placeholder="WB-01-XX-1234" required></div>
    <div class="form-group"><label>Owner Name</label><input name="owner_name" class="form-control" required></div>
    <div class="form-group"><label>Contact</label><input name="contact" class="form-control" placeholder="98000..."></div>
    <div class="form-group"><label>Capacity</label><input name="capacity" type="number" class="form-control" value="4" min="1"></div>
    <div class="form-group" style="align-self:flex-end"><button class="btn btn-primary">Add Vehicle</button></div>
  </form>
</div>

<div class="table-wrap">
  <table class="admin-table">
    <thead><tr><th>#</th><th>Vehicle</th><th>Plate</th><th>Owner</th><th>Contact</th><th>Capacity</th><th></th></tr></thead>
    <tbody>
      <% vehicles.filter(v=>v.is_active).forEach(v => { %>
      <tr>
        <td><%= v.id %></td>
        <td><%= v.vehicle_name %></td>
        <td><%= v.plate_number %></td>
        <td><%= v.owner_name %></td>
        <td><%= v.contact %></td>
        <td><%= v.capacity %></td>
        <td>
          <form method="POST" action="/admin/vehicles/<%= v.id %>/delete" onsubmit="return confirm('Remove this vehicle?')">
            <button class="btn btn-sm btn-danger">Remove</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/admin-end') %>
<%- include('../partials/footer') %>
