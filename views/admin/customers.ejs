<%- include('../partials/header', {title: 'Customers'}) %>
<% let currentPage = 'customers' %>
<%- include('../partials/admin-sidebar') %>

<div class="admin-page-header">
  <h1>Customers</h1>
</div>

<div class="table-wrap">
  <table class="admin-table">
    <thead><tr>
      <th>#</th><th>Name</th><th>Email</th><th>Bookings</th><th>Joined</th>
    </tr></thead>
    <tbody>
      <% customers.forEach(c => { %>
      <tr>
        <td><%= c.id %></td>
        <td><%= c.name %></td>
        <td><%= c.email %></td>
        <td><%= c.booking_count %></td>
        <td><%= c.created_at?.split('T')[0] || c.created_at %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/admin-end') %>
<%- include('../partials/footer') %>
